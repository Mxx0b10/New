{
  "manifest_version": 3,
  "name": "ListenFlow",
  "version": "1.0.0",
  "description": "Listen to any webpage content with one click — Wispr-like TTS overlay for ChatGPT, Perplexity, blogs and more.",

  "permissions": [],

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],

  "background": {
    "service_worker": "background.js"
  },

  "action": {
    "default_title": "ListenFlow",
    "default_icon": {
      "16":  "icons/icon16.png",
      "48":  "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },

  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "web_accessible_resources": []
}
